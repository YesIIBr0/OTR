# --- OTR Aula · variables de entorno ---
# Copia este archivo a .env y rellena los valores.

# Base de datos.
# Desarrollo (SQLite):   file:./prisma/dev.db
# Producción (Hostinger, PostgreSQL): postgresql://USER:PASS@HOST:5432/DBNAME?schema=public
DATABASE_URL="file:./prisma/dev.db"

# Secreto para firmar la sesión (HMAC). OBLIGATORIO. Mínimo 16 caracteres.
# Genera uno fuerte:  openssl rand -hex 32
AUTH_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio"

# Stripe (opcional — solo si vendes cursos de pago).
# Sin estas claves, la inscripción a cursos con precio se hace directa (modo manual/gratis).
STRIPE_SECRET_KEY=""
# Secreto del endpoint de webhook (Dashboard de Stripe → Developers → Webhooks).
# Apunta el webhook a: https://TU-DOMINIO/api/stripe/webhook  (evento checkout.session.completed)
STRIPE_WEBHOOK_SECRET=""

# Cloudflare Stream (opcional — para video del LMS).
# Sin estas variables, el embed usa el iframe público genérico (funciona pegando el UID de un video público).
# Con el subdominio de cliente, se usa la URL específica de tu cuenta; el API token habilita
# (follow-up) la subida directa y los tokens firmados de reproducción para video protegido.
CLOUDFLARE_CUSTOMER_SUBDOMAIN=""
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_API_TOKEN=""
