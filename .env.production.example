# ============================================================
#  OTR Academy · variables de entorno de PRODUCCIÓN
#  Copia este archivo a .env.production y rellena los valores reales.
#  NUNCA comitees .env.production (está en .gitignore).
# ============================================================

# --- Base de datos (PostgreSQL) ---------------------------------------------
# VPS con Postgres local:
#   postgresql://USUARIO:CONTRASENA@localhost:5432/otr_aula?schema=public
# Con docker-compose (host = nombre del servicio "postgres"):
#   postgresql://otr:CONTRASENA@postgres:5432/otr_aula?schema=public
# connection_limit=30 evita el colapso bajo concurrencia (login de clase entera).
DATABASE_URL="postgresql://otr:CAMBIA_ESTA_CONTRASENA@localhost:5432/otr_aula?schema=public&connection_limit=30&pool_timeout=20"

# Credenciales del contenedor Postgres (solo si usas docker-compose).
POSTGRES_USER="otr"
POSTGRES_PASSWORD="CAMBIA_ESTA_CONTRASENA"
POSTGRES_DB="otr_aula"

# --- Seguridad ---------------------------------------------------------------
# Secreto para firmar la sesión (HMAC). OBLIGATORIO. Mínimo 16 caracteres.
# Genera uno fuerte:  openssl rand -hex 32
AUTH_SECRET="CAMBIA_POR_UN_SECRETO_LARGO_Y_ALEATORIO_openssl_rand_hex_32"

# --- URL pública de la app ---------------------------------------------------
# Se usa para construir el enlace de recuperación de contraseña, etc.
APP_URL="https://otr-academy.com"

# --- Email (SMTP) ------------------------------------------------------------
# Si se define, los correos (recuperación de contraseña) se envían vía SMTP.
# Si se deja vacío, los correos se loguean a consola (fallback dev).
# Formato: smtp://USUARIO:CONTRASENA@HOST:587   (o smtps://...:465)
SMTP_URL=""

# --- Stripe (opcional — solo para programas de pago) -------------------------
# Sin estas claves, la inscripción a programas con precio se hace en modo manual.
STRIPE_SECRET_KEY=""
# Webhook → https://TU-DOMINIO/api/stripe/webhook  (evento checkout.session.completed)
STRIPE_WEBHOOK_SECRET=""

# --- Cloudflare Stream (opcional — video del LMS) ----------------------------
# Sin estas variables, el embed usa el iframe público (funciona con UID público).
CLOUDFLARE_CUSTOMER_SUBDOMAIN=""
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_API_TOKEN=""
